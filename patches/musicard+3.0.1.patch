+    context.fillText(trackName, PAD, 974);
+
+    context.shadowColor = 'transparent'; context.shadowBlur = 0;
+    context.font        = `${artistStyle.textItalic ? 'italic' : 'normal'} 36px ${GlobalFonts}`;
+    context.fillStyle   = artistStyle.textColor || 'white';
+    if (artistStyle.textGlow) {
+        context.shadowColor = artistStyle.textColor || 'white';
+        context.shadowBlur = 30; context.shadowOffsetX = 0; context.shadowOffsetY = 0;
+    }
+    context.fillText(artistName, isExplicit ? PAD + 59 : PAD, 1040);
+
+    context.shadowColor  = 'transparent'; context.shadowBlur = 0;
+    context.font         = `${timeStyle.textItalic ? 'italic' : 'normal'} 26px ${GlobalFonts}`;
+    context.fillStyle    = timeStyle.textColor || 'white';
+    context.textBaseline = 'middle';
+    context.textAlign    = 'left';
+    context.fillText(timeStart, PAD, TIME_CY);
+    context.textAlign    = 'right';
+    context.fillText(timeEnd, W - PAD, TIME_CY);
+    context.textAlign    = 'start';
+    context.textBaseline = 'alphabetic';
+
+    return cropImage({ imagePath: canvas.toBuffer('image/png'), width: W, height: H, borderRadius: 0 });
+};
+
+export default HazePortrait;
