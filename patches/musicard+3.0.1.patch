@@ -0,0 +1,162 @@
+import generateSvg from '../Functions/GenerateSvg.js';
+import { cropImage } from 'cropify';
+import { createCanvas, loadImage } from '@napi-rs/canvas';
+import { GlobalFonts } from '../fonts.js';
+
+// Canvas: 900 × 1200  (3 : 4)
+// Top 900 px  → square album art with padding on sides and top
+// Bottom 300 px → info section with blurred art shade + text
+const W       = 900;
+const H       = 1200;
+const INFO_Y  = 900;
+const PAD     = 40;
+const ART_PAD = 40;
+const ART_SZ  = W - 2 * ART_PAD;   // 820 — square art
+const ART_TOP = ART_PAD;            // 40px from top
+const BAR_W   = W - PAD * 2;        // 820
+const BAR_Y   = 1088;
+const BAR_H   = 14;
+const TIME_CY = 1148;
+
+const BloomPortraitBS = ({
+    isExplicit       = false,
+    progressBar      = 0,
+    progressBarStyle = { barColor: '#fff', barColorDuo: false },
+    backgroundColor  = 'black',
+    explicitColor    = 'white',
+    explicitOpacity  = 0.48,
+} = {}) => {
+    const safeProgress  = Number.isFinite(progressBar) ? progressBar : 0;
+    const progressWidth = (Math.min(Math.max(safeProgress, 0), 100) / 100) * BAR_W;
+    const trackColor    = progressBarStyle.barColorDuo ? progressBarStyle.barColor : 'white';
+
+    const explicitBadge = isExplicit
+        ? `<path fill-rule="evenodd" clip-rule="evenodd" d="M56.333 1020C47.313 1020 40 1027.313 40 1036.333V1052.667C40 1061.687 47.313 1069 56.333 1069H72.667C81.687 1069 89 1061.687 89 1052.667V1036.333C89 1027.313 81.687 1020 72.667 1020H56.333ZM63.31 1042.722V1038.47H71.066V1034.368H58.19V1055.389H71.066V1051.287H63.31V1046.675H70.168V1042.722H63.31Z" fill="${explicitColor}" fill-opacity="${explicitOpacity}"/>`
+        : '';
+
+    return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" fill="none" xmlns="http://www.w3.org/2000/svg">
+<rect x="0" y="${INFO_Y}" width="${W}" height="${H - INFO_Y}" fill="${backgroundColor}" fill-opacity="0.45"/>
+<rect width="${W}" height="${H}" fill="url(#bloomPortraitFade)"/>
+<rect x="${PAD}" y="${BAR_Y}" width="${BAR_W}" height="${BAR_H}" rx="${BAR_H / 2}" fill="${trackColor}" fill-opacity="0.18"/>
+<rect x="${PAD}" y="${BAR_Y}" width="${progressWidth}" height="${BAR_H}" rx="${BAR_H / 2}" fill="${progressBarStyle.barColor}"/>
+${explicitBadge}
+<defs>
+  <linearGradient id="bloomPortraitFade" x1="0" y1="${ART_TOP + ART_SZ - 60}" x2="0" y2="${INFO_Y}" gradientUnits="userSpaceOnUse">
+    <stop stop-color="${backgroundColor}" stop-opacity="0"/>
+    <stop offset="1" stop-color="${backgroundColor}" stop-opacity="0.45"/>
+  </linearGradient>
+</defs>
+</svg>`;
+};
+
+export const BloomPortrait = async ({
+    albumArt,
+    fallbackArt,
+    artistName   = 'Unknown Artist',
+    trackName    = 'Unknown Track',
+    timeAdjust:  { timeStart, timeEnd } = { timeStart: '0:00', timeEnd: '0:00' },
+    progressBar  = 0,
+    styleConfig: {
+        artistStyle      = { textColor: 'white', textItalic: false, textGlow: false },
+        trackStyle       = { textColor: 'white', textItalic: false, textGlow: false },
+        timeStyle        = { textColor: 'white', textItalic: false },
+        progressBarStyle = { barColor: 'white', barColorDuo: false },
+        explicitStyle    = { iconColor: 'white', iconOpacity: 48 },
+    } = {},
+    isExplicit      = false,
+    backgroundColor = 'black',
+}) => {
+    if (artistName.length > 28) artistName = artistName.substring(0, 25) + '...';
+    if (trackName.length  > 28) trackName  = trackName.substring(0, 25)  + '...';
+
+    const structure = generateSvg(BloomPortraitBS({
+        isExplicit,
+        progressBar,
+        progressBarStyle,
+        backgroundColor,
+        explicitColor:   explicitStyle.iconColor,
+        explicitOpacity: (explicitStyle.iconOpacity || 48) / 100,
+    }));
+
+    const canvas  = createCanvas(W, H);
+    const context = canvas.getContext('2d');
+
+    // ── Solid base ────────────────────────────────────────────────────────────
+    context.fillStyle = backgroundColor;
+    context.fillRect(0, 0, W, H);
+
+    // ── Load art ──────────────────────────────────────────────────────────────
+    let artImage;
+    try {
+        artImage = await loadImage(await cropImage({ imagePath: albumArt,    width: ART_SZ, height: ART_SZ, borderRadius: 0 }));
+    } catch {
+        if (fallbackArt) {
+            try {
+                artImage = await loadImage(await cropImage({ imagePath: fallbackArt, width: ART_SZ, height: ART_SZ, borderRadius: 0 }));
+            } catch { /* no art available */ }
+        }
+    }
+
+    // ── Blurred art — drawn behind everything, centred over the info section ──
+    // Drawn BEFORE the sharp art so the sharp art sits cleanly on top.
+    // No clip needed: the sharp art covers the blurred layer in the art area.
+    if (artImage) {
+        context.filter = 'blur(60px) opacity(0.8)';
+        // Scale to full canvas width, centre vertically at INFO_Y so the colour
+        // pool sits naturally in the info section and bleeds softly upward.
+        context.drawImage(artImage, 0, INFO_Y - W / 2, W, W);
+        context.filter = 'none';
+    }
+
+    // ── Sharp album art on top — padded 40px from top and sides ──────────────
+    if (artImage) context.drawImage(artImage, ART_PAD, ART_TOP, ART_SZ, ART_SZ);
+
+    // ── SVG overlay: gradient fade + info section dimmer + progress bar ───────
+    context.drawImage(await loadImage(structure), 0, 0);
+
+    // ── Track name ────────────────────────────────────────────────────────────
+    context.font      = `${trackStyle.textItalic ? 'italic' : 'normal'} 800 52px ${GlobalFonts}`;
+    context.fillStyle = trackStyle.textColor || 'white';
+    if (trackStyle.textGlow) {
+        context.shadowColor   = trackStyle.textColor || 'white';
+        context.shadowBlur    = 40;
+        context.shadowOffsetX = 0;
+        context.shadowOffsetY = 0;
+    }
+    context.fillText(trackName, PAD, 974);
+
+    // ── Artist name ───────────────────────────────────────────────────────────
+    context.shadowColor   = 'transparent';
+    context.shadowBlur    = 0;
+    context.font          = `${artistStyle.textItalic ? 'italic' : 'normal'} 36px ${GlobalFonts}`;
+    context.fillStyle     = artistStyle.textColor || 'white';
+    if (artistStyle.textGlow) {
+        context.shadowColor   = artistStyle.textColor || 'white';
+        context.shadowBlur    = 30;
+        context.shadowOffsetX = 0;
+        context.shadowOffsetY = 0;
+    }
+    context.fillText(artistName, isExplicit ? PAD + 59 : PAD, 1040);
+
+    // ── Timestamps ────────────────────────────────────────────────────────────
+    context.shadowColor   = 'transparent';
+    context.shadowBlur    = 0;
+    context.font          = `${timeStyle.textItalic ? 'italic' : 'normal'} 26px ${GlobalFonts}`;
+    context.fillStyle     = timeStyle.textColor || 'white';
+    context.textAlign     = 'left';
+    context.textBaseline  = 'middle';
+    context.fillText(timeStart, PAD,     TIME_CY);
+    context.textAlign     = 'right';
+    context.fillText(timeEnd,   W - PAD, TIME_CY);
+    context.textAlign     = 'start';
+    context.textBaseline  = 'alphabetic';
+
+    return cropImage({
+        imagePath:    canvas.toBuffer('image/png'),
+        width:        W,
+        height:       H,
+        borderRadius: 0,
+    });
+};
+
+export default BloomPortrait;
