+        timeStyle?:        { textColor?: string; textItalic?: boolean; };
+        progressBarStyle?: { barColor?: string; barColorDuo?: boolean; };
+        volumeBarStyle?:   { barColor?: string; barColorDuo?: boolean; };
+        explicitStyle?:    { iconColor?: string; iconOpacity?: number; };
+    };
